# ─── PortKey / Galileo AI Gateway ────────────────────────────────────────────
# Your API key for the Galileo/PortKey gateway.
PORTKEY_API_KEY=your_api_key_here

# Gateway endpoints (defaults shown – change only if instructed by your admin)
PORTKEY_RCN_URL=https://us.aigw.galileo.roche.com/v1
PORTKEY_WAF_URL=https://waf-us.aigw.galileo.roche.com/v1
PORTKEY_HEALTH_URL=https://us.aigw.galileo.roche.com/v1/health

# Model to use (must be supported by the gateway)
PORTKEY_MODEL_ID=gemini-2.5-pro

# LLM call settings
PORTKEY_TIMEOUT=120        # seconds
PORTKEY_MAX_TOKENS=8192

# ─── ChemConverter / CAS SciFinder ───────────────────────────────────────────
# Required for CASClient authentication (see ChemConverter/cas_client.py)
CAS_CLIENT_ID=your_cas_client_id
CAS_CLIENT_SECRET=your_cas_client_secret
CAS_TOKEN_URL=https://your-cas-oauth-endpoint/token
CAS_SERVER=https://your-cas-api-server
CAS_SCOPE=openid

# ─── Application ──────────────────────────────────────────────────────────────
PORT=8000
DEV=false       # Set to "true" for hot-reload during development
